{
  "name": "cyber",
  "displayName": "Cyber",
  "description": "Syntax highlighting for Cyber and Doe",
  "version": "0.0.1",
  "publisher": "doe",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "cyber",
      "aliases": ["Cyber", "cyber", "Doe", "doe"],
      "extensions": [".cy", ".cys", ".cyber", ".do"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "cyber",
      "scopeName": "source.cyber",
      "path": "./syntaxes/cyber.tmLanguage.json"
    }]
  }
}
